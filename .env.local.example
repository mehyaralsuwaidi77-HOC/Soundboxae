# ── Supabase (required for production) ────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-role-key   # server-side only, never expose to client

# ── Admin credentials (used by npm run admin:create) ──────────────────────────
ADMIN_EMAIL=admin@soundboxdubai.com
ADMIN_INITIAL_PASSWORD=your-secure-password

# ── Admin Dashboard (legacy fallback — used when Supabase is NOT configured) ───
# Only needed if you are not using Supabase Auth
NEXT_PUBLIC_ADMIN_PASSWORD=soundbox2025

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.soundboxdubai.com

# ── Email Notifications (optional) ────────────────────────────────────────────
# Configure to receive email alerts when a new lead or booking is submitted
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=info@soundboxdubai.com

# ── WhatsApp Business API (optional) ──────────────────────────────────────────
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_ID=your_phone_number_id
NOTIFY_WHATSAPP=971553320051

# ── Payment Gateway (optional) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
